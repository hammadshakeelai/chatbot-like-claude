# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in a key for the provider you want to use.
# All providers below are OpenAI-compatible, so the app works with any of them.
# ---------------------------------------------------------------------------

# Which provider to use: groq | openrouter | cerebras | mistral | fireworks
PROVIDER=groq

# (Optional) override the default model for the chosen provider
# MODEL=llama-3.3-70b-versatile

# Only the key for your chosen PROVIDER needs a real value.
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
FIREWORKS_API_KEY=

# (Optional) change the port the server runs on (default 3000)
# PORT=3000
