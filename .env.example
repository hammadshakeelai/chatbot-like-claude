# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in keys for the features you want.
# Every chat provider below is OpenAI-compatible. Keys are read from the
# environment only — never commit your real .env.
# ---------------------------------------------------------------------------

# Default chat provider (the UI can switch between any of these):
# groq | cerebras | openrouter | mistral | fireworks | opencode | gemini
PROVIDER=groq

# (Optional) override the default model for the chosen provider
# MODEL=llama-3.3-70b-versatile

# ---- Chat providers (only the ones you use need a real value) -------------
GROQ_API_KEY=          # also powers voice (Whisper), vision, auto-titles
OPENROUTER_API_KEY=    # also powers image generation (/image)
CEREBRAS_API_KEY=
MISTRAL_API_KEY=       # also the vision fallback
FIREWORKS_API_KEY=
OPENCODE_API_KEY=

# Gemini is free-tier and quota-limited. You can add backup keys for automatic
# failover on 429 errors — use numbered keys and/or a comma-separated list:
GEMINI_API_KEY=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEYS=key_a,key_b,key_c
#
# (Failover works for any provider — e.g. GROQ_API_KEY_2 — not just Gemini.)

# ---- ElevenLabs (read-aloud / text-to-speech) -----------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=   # a voice id from your ElevenLabs account

# (Optional) change the port the server runs on (default 3000)
# PORT=3000
